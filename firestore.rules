rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Replace with a secure admin check if you have an admin collection
      // return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      return isAuthenticated(); // Temporary allowing for testing
    }

    // Users Collection
    match /users/{userId} {
      // Users can only read and write their own data
      allow read: if isOwner(userId);
      
      // Updates are strictly validated to prevent coin manipulation
      allow update: if isOwner(userId) 
        // Example check: Users cannot magically give themselves coins directly via raw writes without going through Cloud Functions 
        // If you are relying on client-side updates (like currently), you MUST at least ensure the fields are of correct type
        && request.resource.data.coins is number
        && request.resource.data.totalEarned is number;
        
      allow create: if isOwner(userId);
    }

    // Transactions Collection (Users can only read/write their own transactions)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Prevent users from creating fake transactions to get coins
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.coins is number;
        
      allow update, delete: if false; // Transactions should never be updated or deleted by clients
    }

    // Withdrawals Collection
    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated(); // So everyone can see recent withdrawals
      
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount > 0;
        
      allow update: if isAdmin(); // Only admins can approve/reject withdrawals
    }

    // Videos / Shorts Collection
    match /videos/{videoId} {
      allow read: if isAuthenticated(); // Anyone logged in can watch videos
      allow write: if isAdmin(); // Only admins can upload/delete videos
    }

    // AI Users Collection (Leaderboard)
    match /ai_users/{aiId} {
      allow read: if isAuthenticated(); // Anyone can see the leaderboard
      allow write: if isAdmin(); // Only admins can generate base AI users
    }
    
    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
